df["revol_util"] = df["revol_util"].fillna(df["revol_util"].median())
df["mort_acc"] = df["mort_acc"].fillna(df["mort_acc"].median())
df["pub_rec_bankruptcies"] = df["pub_rec_bankruptcies"].fillna(df["pub_rec_bankruptcies"].median())


# %%
df.isna().sum()

# %%
data_empregos = {
    "< 1 year":0,
    "1 year":1,
    "2 years":2,
    "3 years":3,
    "4 years":4,
    "5 years":5,
    "6 years":6,
    "7 years":7,
    "8 years":8,
    "9 years":9,
    "10+ years":10
}

# %%
df["emp_length"] = df["emp_length"].map(data_empregos)

# %%
df["emp_length"] = df["emp_length"].fillna(df["emp_length"]).median()

# %%
df = df.drop(["title", "emp_title", "initial_list_status", "verification_status"], axis=1)

